AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate
AGENT_GREETING=Hi! I'm your configurable assistant. Ask me anything.
# OPENAI_API_KEY is optional — Agora manages the OpenAI key by default (keyless).
# Set it only if your Agora account requires a bring-your-own OpenAI key.
# OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini
REPLY_STYLE=normal
ASSISTANT_NAME=Ada
AGENT_EXIT_MESSAGE=Thanks for chatting — goodbye!
